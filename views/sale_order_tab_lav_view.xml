<odoo>

           crm.lead.tag views
        -->
        <record id="x_product_load_tag_form" model="ir.ui.view">
            <field name="name">x.product.load.tag.form</field>
            <field name="model">x.product.load.tag</field>
            <field name="arch" type="xml">
                <form string="Tags">
                    <sheet>
                        <div class="oe_title">
                            <div class="oe_edit_only">
                                <label for="name"/>
                            </div>
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="color" required="True"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="x_product_load_tag_tree" model="ir.ui.view">
            <field name="name">x.product.load.tag.tree</field>
            <field name="model">x.product.load.tag</field>
            <field name="arch" type="xml">
                <tree string="Tags" editable="bottom">
                    <field name="name"/>
                    <field name="color" groups="base.group_no_one"/>
                </tree>
            </field>
        </record>




<record id="product_category_form_inherit_lavorazione" model="ir.ui.view">
    <field name="name">product.category.form.inherit.lavorazione</field>
    <field name="model">product.category</field>
    <field name="inherit_id" ref="product.product_category_form_view"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='parent_id']" position="after">
            <field name="x_lavorazione"/>
        </xpath>
    </field>
</record>


    <!-- TREE -->
    <record id="view_x_product_load_tree" model="ir.ui.view">
        <field name="name">x.product.load.tree</field>
        <field name="model">x.product.load</field>
        <field name="arch" type="xml">
            <tree string="Caricamenti prodotti">
                <field name="name"/>
                <field name="note"/>
            </tree>
        </field>
    </record>
    <record id="view_x_product_load_line_tree" model="ir.ui.view">
        <field name="name">x.product.load.line.tree</field>
        <field name="model">x.product.load.line</field>
        <field name="arch" type="xml">
            <tree string="prodotti selezionbili prodotti">
                <field name="tag_true"   optional="show"/>
                <field name="tag_ids" optional="show" widget="many2many_tags"/>
                <field name="product_id"/>
                <field name="x_lavorazione"/>
                <field name="note"/>
                <field name="uom_id" readonly="1"/>
                <field name="product_uom_height" optional="show" />
                <field name="product_uom_length" optional="show" />
                <field name="product_uom_width" optional="show" />
                <field name="product_uom_qty"/>
                <field name="price_unit"/>
                <field name="price_extra" optional="show" />
                <field name="tipo_vetrina" optional="show" />

            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_x_product_load_form" model="ir.ui.view">
        <field name="name">x.product.load.form</field>
        <field name="model">x.product.load</field>
        <field name="arch" type="xml">
            <form string="Caricamento prodotti">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="note"/>
                    </group>

                    <notebook>
                        <page string="Prodotti">
                            <button name="action_add_section_line"
                                type="object"
                                string="Aggiungi sezione"
                                class="oe_highlight"/>
                            <field name="line_ids"
                                   context="{'default_load_id': active_id}"
                                    limit="100"
                                   >
                                <tree editable="bottom" limit="100">
                                    <control>
                                        <create string="Aggiungi riga"/>

                                    </control>

                                    <field name="sequence" widget="handle"/>
                                    <field name="display_type" invisible="1"/>
                                    <field name="name" string="Descrizione" widget="section_and_note_text"  attrs="{'readonly': [('display_type','=',False)]}"/>
                                <field name="tag_true"  attrs="{'invisible': [('display_type','!=',False)]}" optional="show"/>
                                <field name="tag_ids" widget="many2many_tags" optional="show"
       attrs="{'invisible': [('display_type','!=',False)],'required': [('tag_true', '=', True)]}"/>
                                    <field name="editable"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="tipo_vetrina"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="product_id"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="x_lavorazione"
       attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="default_code" readonly="1"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="uom_id" readonly="1"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="product_uom_height" optional="show"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="product_uom_length" optional="show"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="product_uom_width" optional="show"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="product_uom_qty"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="price_unit"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="price_extra" optional="show"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="supplier_id"
                                           domain="[('commercial_partner_id.property_supplier_payment_term_id','!=',False)]"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                    <field name="note"
                                           attrs="{'invisible': [('display_type','!=',False)]}"/>
                                </tree>

                             </field>
                         </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>









    <!-- ACTION -->
    <record id="action_x_product_load" model="ir.actions.act_window">
        <field name="name">Caricamento Prodotti</field>
        <field name="res_model">x.product.load</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_x_product_load_tags" model="ir.actions.act_window">
        <field name="name">Etichette</field>
        <field name="res_model">x.product.load.tag</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- MENU: visibile solo Sales Manager -->
    <menuitem id="menu_x_product_load_root"
              name="Caricamenti Prodotti"
              parent="sale.menu_sale_config"
              groups="sales_team.group_sale_manager,lasercom_2_13.group_admin_lav"
              sequence="200"/>

    <menuitem id="menu_x_product_load"
              name="Caricamento Prodotti"
              parent="menu_x_product_load_root"
              action="action_x_product_load"
              groups="sales_team.group_sale_manager,lasercom_2_13.group_admin_lav"
              sequence="10"/>
    <menuitem id="menu_x_product_load_tag"
              name="Etichette"
              parent="menu_x_product_load_root"
              action="action_x_product_load_tags"
              groups="sales_team.group_sale_manager,lasercom_2_13.group_admin_lav"
              sequence="125"/>

    <menuitem id="menu_x_product_load_root_2"
              name="Caricamenti Prodotti"
              parent="sale.menu_products"
              groups="sales_team.group_sale_manager,lasercom_2_13.group_admin_lav"
              sequence="200"/>

    <menuitem id="menu_x_product_load_2"
              name="Caricamento Prodotti"
              parent="menu_x_product_load_root_2"
              action="action_x_product_load"
              groups="sales_team.group_sale_manager,lasercom_2_13.group_admin_lav"
              sequence="10"/>
    <menuitem id="menu_x_product_load_tag_2"
              name="Etichette"
              parent="menu_x_product_load_root_2"
              action="action_x_product_load_tags"
              groups="sales_team.group_sale_manager,lasercom_2_13.group_admin_lav"
              sequence="125"/>





    <record id="view_res_config_settings_inherit_x_product_load" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.x.product.load</field>
        <field name="model">res.config.settings</field>
        <!-- Nota: erediti la vista BASE, non quella di sale, così sei compatibile con il tuo layout -->
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- Aggancio stabile: dentro la sezione contenuti -->
            <xpath expr="//div[contains(@class,'settings')]" position="inside">
                <div class="app_settings_block" data-string="Caricamento Prodotti" string="Caricamento Prodotti">
                    <h2>Caricamento Prodotti</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="x_default_product_load_id"/>
                                <div class="text-muted">
                                    Se selezionato, verrà proposto automaticamente negli Ordini di Vendita della stessa azienda.
                                </div>
                                <field name="x_default_product_load_id" options="{'no_create': True}"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>

        </field>
    </record>






    <record id="view_sale_order_form_inherit_x_product_load" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.x.product.load</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Caricamento Prodotti" groups="sales_team.group_sale_manager,lasercom_2_13.group_admin_lav">
                    <group>
                        <field name="x_load_id" options="{'no_create': True}"/>
                        <field name="price_subtotal_lav"  widget="monetary"/>
                        <field name="date_module"  widget="date"/>


                        <!-- 16/02/20026 rocco
                        <button name="action_open_import_load_lines_wizard"
                                type="object"
                                string="Seleziona righe dal Caricamento"
                                class="oe_highlight"
                                attrs="{'invisible': [('x_load_id','=',False)]}"/>
                         -->
                        <button name="action_apply_product_load"
                    type="object"
                    string="Applica Caricamento (Sostituisci righe)"
                    class="oe_highlight"
                    attrs="{'invisible': [('x_load_id','=',False)]}"/>

                    </group>
                    <separator string="Righe"/>
                    <group>
                        <field name="x_load_line_ids"
                               nolabel="1"
                                colspan="4"
                                limit="100"
                               widget="section_and_note_one2many">
                            <tree editable="bottom" decoration-info="sale_line_id" limit="100">
                                <control>
                                    <create string="Aggiungi riga"/>
                                    <create string="Aggiungi sezione" context="{'default_display_type': 'line_section'}"/>
                                </control>



                                <field name="x_locked_by_tag"  optional="hide"/>
                                <field name="sequence" widget="handle"/>
                                <field name="sale_line_id" readonly="1" optional="hide"/>
                                <field name="display_type" invisible="1"/>

                                <field name="name" widget="section_and_note_text"  attrs="{'readonly': [('display_type','=',False)],'invisible': [('display_type','=',False)]}"/>
                                <field name="tag_true" optional="hide"  attrs="{'readonly':True}"/>
                                 <field name="tag_ids" widget="many2many_tags" optional="show"
       attrs="{'required': [('tag_true', '=', True)]}"/>
                                <field name="default_code" readonly="1" optional="hide" />
                                <field name="editable" />
                                <field name="etichetta_si"  optional="show" attrs="{'readonly': [('editable','=',False)]}"/>
                                <field name="product_id"  attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}" />
                                <field name="x_lavorazione"
       attrs="{'invisible': [('display_type','!=',False)]}" optional="hide"/>
                                <field name="tipo_vetrina" optional="hide" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="product_uom_qty" optional="show" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="price_unit" optional="show" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="price_extra" optional="show" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="price_subtotal" optional="hide" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="uom_id" readonly="1" optional="hide" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="product_uom_height" optional="show" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="product_uom_length" optional="show" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="product_uom_width" optional="show" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="supplier_id" domain="[('commercial_partner_id.property_supplier_payment_term_id','!=',False)]" optional="hide" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                                <field name="note" optional="hide" attrs="{'readonly': ['|',('x_locked_by_tag', '=', True),('editable','=',False)]}"/>
                            </tree>



                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>




</odoo>

